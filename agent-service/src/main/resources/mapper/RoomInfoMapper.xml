<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zju.lease.agent.mapper.RoomInfoMapper">
    <select id="selectAllReleasedRooms" resultType="com.zju.lease.model.entity.RoomInfo">
        select id,
               room_number,
               rent,
               apartment_id,
               is_release
        from room_info
        where is_deleted = 0
          and is_release = 1
    </select>
</mapper>
