<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zju.lease.agent.mapper.RoomFacilityMapper">
    <select id="selectListByRoomId" resultType="com.zju.lease.model.entity.FacilityInfo">
        select fi.id,
               fi.name,
               fi.type
        from facility_info fi
        where fi.is_deleted = 0
          and fi.id in (select facility_id
                        from room_facility
                        where is_deleted = 0
                          and room_id = #{roomId})
    </select>
</mapper>
